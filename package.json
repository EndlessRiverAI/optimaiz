{
  "name": "optimaiz",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source LLM observability platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @optimaiz/server dev",
    "dev:sdk": "pnpm --filter @optimaiz/sdk dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "llm",
    "observability",
    "tracing",
    "openai",
    "anthropic",
    "gemini",
    "langchain",
    "ai",
    "monitoring",
    "analytics"
  ],
  "author": "Optimaiz",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
